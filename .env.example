# ============================================
# KG-BOOKING Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Google Apps Script Web App URL (required)
# Deploy your GAS backend, then paste the exec URL here
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Cloudflare R2 Image Worker URL (optional)
# If not set, images will be uploaded via GAS → Google Drive fallback
VITE_R2_URL=

# App Configuration (optional)
VITE_APP_TITLE=KING's GRILL Manager AI v2.0
